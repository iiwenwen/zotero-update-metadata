{
  "name": "zotero-update-metadata",
  "type": "module",
  "version": "1.1.3",
  "description": "Zotero update metadata for translation ",
  "config": {
    "addonName": "Zotero update Metadata",
    "addonID": "zotero-update-metadata@iiwenwen",
    "addonRef": "updatemetadata",
    "addonInstance": "UpdateMetadata",
    "prefsPrefix": "extensions.zotero.updatemetadata",
    "releasePage": "https://cnb.cool/iisyaoran/zotero-update-metadata/-/releases",
    "updateJSON": "https://cnb.cool/iisyaoran/zotero-update-metadata/-/git/raw/main/update.json"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "node scripts/patch-scaffold-cnb-repo-url.mjs && zotero-plugin build --dist build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "lint": "npm run lint:fix",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "node scripts/smoke-metadata-douban-fallback.mjs && node scripts/smoke-dev-runtime-safety.mjs",
    "test:ui": "node scripts/run-zotero-ui-smoke.mjs",
    "release": "release-it --only-version --preReleaseId=beta",
    "update-deps": "npm update --save"
  },
  "repository": {
    "type": "git",
    "url": "git+https://cnb.cool/iisyaoran/zotero-update-metadata.git"
  },
  "author": "iiwenwen",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://cnb.cool/iisyaoran/zotero-update-metadata/-/issues"
  },
  "homepage": "https://cnb.cool/iisyaoran/zotero-update-metadata",
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.4"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "esbuild": "^0.20.2",
    "eslint": "^9.39.4",
    "prettier": "^3.9.0",
    "release-it": "^17.10.0",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  },
  "release-it": {
    "git": {
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": "npm run lint",
      "after:bump": "npm run build"
    }
  }
}

# Copy this file to `.env` and keep `.env` out of git.

# Zotero executable used by `npm start`.
# macOS example:
ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/Applications/Zotero.app/Contents/MacOS/zotero

# Isolated development profile. Do not point this at your daily Zotero profile.
ZOTERO_PLUGIN_PROFILE_PATH=/path/to/isolated/zotero/profile

# Isolated development data directory. Leave empty only if you intentionally
# want Zotero to use the profile default data directory.
ZOTERO_PLUGIN_DATA_DIR=/path/to/isolated/zotero/data
